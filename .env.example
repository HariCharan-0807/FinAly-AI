# FinAly AI — Environment Variables Template
# Copy this to .env and fill in your actual values.
# NEVER commit your real .env file to version control.

# ── JWT Authentication ─────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=your-super-secret-key-here
REFRESH_SECRET_KEY=your-refresh-secret-key-here

# ── Fernet Encryption (for MFA secrets at rest) ────────────
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-fernet-key-here

# ── Database ───────────────────────────────────────────────
DATABASE_URL=sqlite:///./.finaly_ai.db

# ── TOTP / MFA ─────────────────────────────────────────────
TOTP_ISSUER_NAME=FinAly AI

# ── Gemini AI (for AI Chat feature) ───────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── Deployment (Frontend points to this backend URL) ───────
# For Vercel + Railway: set this to your Railway backend URL
# Example: https://finaly-ai-backend.railway.app
BACKEND_URL=http://127.0.0.1:8000
